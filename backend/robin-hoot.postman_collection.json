{
  "info": {
    "_postman_id": "robin-hoot-api",
    "name": "Robin HOOT API",
    "description": "Colección completa de endpoints de la API Robin HOOT — quizzes interactivos en tiempo real.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/auth/registrar" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana García\",\n  \"email\": \"ana@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/usuarios/auth/logout" }
          }
        },
        {
          "name": "Perfil (protegido)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/usuarios/perfil" }
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Obtener todos los usuarios",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/usuarios" }
          }
        },
        {
          "name": "Obtener usuario por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/usuarios/:id", "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Actualizar usuario (protegido)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/:id", "variable": [{ "key": "id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana García Actualizada\"\n}"
            }
          }
        },
        {
          "name": "Eliminar usuario (protegido)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/usuarios/:id", "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Categorías",
      "item": [
        {
          "name": "Obtener todas las categorías",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/categorias" }
          }
        },
        {
          "name": "Obtener categoría por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/categorias/:id", "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Crear categoría (protegido)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/categorias" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ciencias\",\n  \"descripcion\": \"Preguntas de ciencias naturales\"\n}"
            }
          }
        },
        {
          "name": "Actualizar categoría (protegido)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/categorias/:id", "variable": [{ "key": "id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descripcion\": \"Preguntas de biología, física y química\"\n}"
            }
          }
        },
        {
          "name": "Eliminar categoría (protegido)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/categorias/:id", "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Obtener todos los productos",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/productos" }
          }
        },
        {
          "name": "Obtener producto por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/productos/:id", "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Crear producto (protegido)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/productos" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Curso de Álgebra\",\n  \"descripcion\": \"Material educativo de álgebra básica\",\n  \"precio\": 29.99,\n  \"categoria\": \"<ID_CATEGORIA>\"\n}"
            }
          }
        },
        {
          "name": "Actualizar producto (protegido)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/productos/:id", "variable": [{ "key": "id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"precio\": 24.99\n}"
            }
          }
        },
        {
          "name": "Eliminar producto (protegido)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/productos/:id", "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    }
  ]
}
